# =============================================================================
# 全国产模型配置（模板）
# =============================================================================
# 复制本文件为 config/models.yaml，填入真实模型配置。
# config/models.yaml 已被 gitignore，不会提交到 GitHub。
#
# 当本文件存在且有效时，应用运行在「托管模式」:
#   - 用户无需在前端配置任何 API Key 或模型
#   - 所有模型选择在此文件中按档位定义
#   - API Key 通过 ${ENV_VAR} 引用 .env（Key 不写进 yaml）
#
# 当本文件缺失时，应用回退到原版「数据库模式」(legacy)，用户在前端自配。
#
# 修改后重启服务，或调用: POST /api/models/reload 热重载。

default_tier: standard

tiers:
  # ---------------------------------------------------------------------------
  # free: 入门档。MiniMax 对话 + 硅基流动 bge-m3 向量化。
  # 两者都有免费额度，零成本起步。
  # ---------------------------------------------------------------------------
  free:
    language:
      provider: openai_compatible
      model: MiniMax-M3
      api_key: ${MINIMAX_API_KEY}
      base_url: https://api.minimaxi.com/v1
    embedding:
      provider: openai_compatible
      model: BAAI/bge-m3
      api_key: ${SILICONFLOW_API_KEY}
      base_url: https://api.siliconflow.cn/v1
    speech_to_text:                  # 硅基流动 SenseVoice，免费
      provider: openai_compatible
      model: FunAudioLLM/SenseVoiceSmall
      api_key: ${SILICONFLOW_API_KEY}
      base_url: https://api.siliconflow.cn/v1

  # ---------------------------------------------------------------------------
  # standard: 平衡档。通义千问 + 硅基流动 bge-m3。
  # ---------------------------------------------------------------------------
  standard:
    language:
      provider: openai_compatible
      model: qwen-plus
      api_key: ${DASHSCOPE_API_KEY}
      base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    embedding:
      provider: openai_compatible
      model: BAAI/bge-m3
      api_key: ${SILICONFLOW_API_KEY}
      base_url: https://api.siliconflow.cn/v1
    speech_to_text:
      provider: openai_compatible
      model: FunAudioLLM/SenseVoiceSmall
      api_key: ${SILICONFLOW_API_KEY}
      base_url: https://api.siliconflow.cn/v1

  # ---------------------------------------------------------------------------
  # premium: 旗舰档。通义千问 Max + 长文本 + bge-m3。
  # ---------------------------------------------------------------------------
  premium:
    language:
      provider: openai_compatible
      model: qwen-max
      api_key: ${DASHSCOPE_API_KEY}
      base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    large_context:                   # 长文本（>105k token）专用
      provider: openai_compatible
      model: qwen-long
      api_key: ${DASHSCOPE_API_KEY}
      base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    embedding:
      provider: openai_compatible
      model: BAAI/bge-m3
      api_key: ${SILICONFLOW_API_KEY}
      base_url: https://api.siliconflow.cn/v1
    speech_to_text:
      provider: openai_compatible
      model: FunAudioLLM/SenseVoiceSmall
      api_key: ${SILICONFLOW_API_KEY}
      base_url: https://api.siliconflow.cn/v1

# =============================================================================
# 国产模型提供商对接方式速查（均为 OpenAI 兼容格式）
# =============================================================================
# | 提供商     | base_url                                          | 模型示例          |
# |------------|---------------------------------------------------|-------------------|
# | 硅基流动   | https://api.siliconflow.cn/v1                     | BAAI/bge-m3 (emb) |
# |            |                                                   | Qwen/DeepSeek/GLM |
# |            |                                                   | SenseVoice (stt)  |
# | 通义千问   | https://dashscope.aliyuncs.com/compatible-mode/v1 | qwen-plus/max     |
# | MiniMax    | https://api.minimaxi.com/v1                       | MiniMax-M3        |
# | 智谱 GLM   | https://open.bigmodel.cn/api/paas/v4              | glm-4-plus        |
# | DeepSeek   | https://api.deepseek.com/v1                       | deepseek-chat/R1  |
# | 月之暗面   | https://api.moonshot.cn/v1                        | moonshot-v1-8k    |
# | 字节豆包   | https://ark.cn-beijing.volces.com/api/v3          | doubao-pro        |
# | 百川       | https://api.baichuan-ai.com/v1                    | Baichuan4         |
# =============================================================================
#
# 支持的用途（每档位）:
#   language          — 对话/问答/摘要（必填）
#   embedding         — 向量检索（必填）
#   speech_to_text    — 音频转写（可选）
#   text_to_speech    — 播客语音合成（可选）
#   large_context     — 长文本（>105k token）专用（可选）
#
# chat/tools/transformation 请求都映射到 language。
# 档位缺少某用途时，自动回退到 default_tier。
